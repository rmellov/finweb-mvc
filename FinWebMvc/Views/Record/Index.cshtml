@model IEnumerable<FinWebMvc.Models.Record>
@{
    decimal pendingExpenses = 0.0m;
    decimal Expenses = 0.0m;
    decimal pendingIncomes = 0.0m;
    decimal Incomes = 0.0m;
}

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

@foreach (var item in Model)
{
    if (!item.Done && item.Type == ETypeRecord.Expense)
    {
        pendingExpenses += item.Value;
    }
    else if (item.Done && item.Type == ETypeRecord.Expense)
    {
        Expenses += item.Value;
    }
    else if (!item.Done && item.Type == ETypeRecord.Income)
    {
        pendingIncomes += item.Value;
    }
    else
    {
        Incomes += item.Value;
    }
}

<div class="form-control">
    <p>Pending Expenses: @pendingExpenses</p>
    <p>Pending Incomes: @pendingIncomes</p>
    <p>Expenses: @Expenses</p>
    <p>Incomes: @Incomes</p>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Value)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Type)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Done)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FinishedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Value)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Category.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CreatedAt)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Type)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Done)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FinishedAt)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
